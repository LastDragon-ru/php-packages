{
  "name": "lastdragon-ru/lara-asp-dev",
  "homepage": "https://github.com/LastDragon-ru/php-packages",
  "description": "Various internal tools and helpers to develop the package itself.",
  "readme": "README.md",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "php",
    "dev",
    "phpstan",
    "phpstan-rule",
    "phpstan-extension"
  ],
  "support": {
    "issues": "https://github.com/LastDragon-ru/php-packages/issues",
    "source": "https://github.com/LastDragon-ru/php-packages",
    "forum": "https://github.com/LastDragon-ru/php-packages/discussions"
  },
  "require": {
    "php": "^8.4|^8.5",
    "ext-mbstring": "*",
    "illuminate/container": "^13.0.0",
    "illuminate/contracts": "^13.0.0",
    "illuminate/support": "^13.0.0",
    "lastdragon-ru/lara-asp-core": "self.version",
    "lastdragon-ru/lara-asp-documentator": "self.version",
    "lastdragon-ru/path": "self.version",
    "nikic/php-parser": "^5.7.0",
    "nette/neon": "^3.4.4",
    "phpstan/phpstan": "^2.1.1",
    "symfony/polyfill-php85": "^1.33.0",
    "symfony/var-dumper": "^8.0.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5.8"
  },
  "autoload": {
    "psr-4": {
      "LastDragon_ru\\LaraASP\\Dev\\": "src/"
    }
  },
  "conflict": {
    "thecodingmachine/safe": "<3.0.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "LastDragon_ru\\LaraASP\\Dev\\PackageProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
