{
  "name": "lastdragon-ru/lara-asp-serializer",
  "homepage": "https://github.com/LastDragon-ru/php-packages",
  "description": "Provides a customizable wrapper around the Symfony Serializer Component to use it inside Laravel application.",
  "readme": "README.md",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "serializer",
    "laravel-package",
    "laravel",
    "symfony",
    "symfony-serializer",
    "php"
  ],
  "support": {
    "issues": "https://github.com/LastDragon-ru/php-packages/issues",
    "source": "https://github.com/LastDragon-ru/php-packages",
    "forum": "https://github.com/LastDragon-ru/php-packages/discussions"
  },
  "require": {
    "php": "^8.4|^8.5",
    "illuminate/contracts": "^13.0.0",
    "illuminate/database": "^13.0.0",
    "illuminate/support": "^13.0.0",
    "lastdragon-ru/lara-asp-core": "self.version",
    "lastdragon-ru/path": "self.version",
    "phpdocumentor/type-resolver": "^1.10.0|^2.0.0",
    "phpstan/phpdoc-parser": "^2.0.0",
    "symfony/property-access": "^8.0.0",
    "symfony/property-info": "^8.0.0",
    "symfony/serializer": "^8.0.0",
    "symfony/type-info": "^8.0.0"
  },
  "require-dev": {
    "lastdragon-ru/lara-asp-testing": "self.version",
    "lastdragon-ru/phpunit-extensions": "self.version",
    "mockery/mockery": "^1.6.6",
    "orchestra/testbench": "^11.0.0",
    "phpunit/phpunit": "^13.0.0"
  },
  "autoload": {
    "psr-4": {
      "LastDragon_ru\\LaraASP\\Serializer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LastDragon_ru\\LaraASP\\Serializer\\Docs\\": "docs"
    },
    "exclude-from-classmap": [
      "docs/"
    ]
  },
  "conflict": {
    "thecodingmachine/safe": "<3.0.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "LastDragon_ru\\LaraASP\\Serializer\\PackageProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
