{
  "name": "lastdragon-ru/lara-asp-testing",
  "homepage": "https://github.com/LastDragon-ru/php-packages",
  "description": "Provides various useful asserts for PHPUnit and better solution for HTTP tests - testing HTTP response has never been so easy!",
  "readme": "README.md",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "testing",
    "laravel-package",
    "laravel",
    "phpunit",
    "phpunit-assertions",
    "php"
  ],
  "support": {
    "issues": "https://github.com/LastDragon-ru/php-packages/issues",
    "source": "https://github.com/LastDragon-ru/php-packages",
    "forum": "https://github.com/LastDragon-ru/php-packages/discussions"
  },
  "require": {
    "php": "^8.4|^8.5",
    "ext-json": "*",
    "ext-dom": "*",
    "ext-mbstring": "*",
    "doctrine/sql-formatter": "^1.1.0",
    "fakerphp/faker": "^1.21.0",
    "illuminate/collections": "^13.0.0",
    "illuminate/console": "^13.0.0",
    "illuminate/contracts": "^13.0.0",
    "illuminate/database": "^13.0.0",
    "illuminate/testing": "^13.0.0",
    "illuminate/translation": "^13.0.0",
    "lastdragon-ru/path": "self.version",
    "lastdragon-ru/phpunit-extensions": "self.version",
    "lastdragon-ru/phpunit-xml": "self.version",
    "nyholm/psr7": "^1.8.0",
    "mockery/mockery": "^1.6.6",
    "opis/json-schema": "^2.3.0",
    "phpunit/phpunit": "^13.0.0",
    "psr/http-message": "^1.1|^2.0",
    "sebastian/comparator": "^8.0.0",
    "symfony/console": "^8.0.4",
    "symfony/http-foundation": "^8.0.0",
    "symfony/mime": "^8.0.0",
    "symfony/polyfill-php85": "^1.33.0",
    "symfony/psr-http-message-bridge": "^8.0.0"
  },
  "require-dev": {
    "illuminate/http": "^13.0.0",
    "laravel/scout": "^10.24.0",
    "orchestra/testbench": "^11.0.0"
  },
  "autoload": {
    "files": [
      "src/mixins.php"
    ],
    "psr-4": {
      "LastDragon_ru\\LaraASP\\Testing\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LastDragon_ru\\LaraASP\\Testing\\Docs\\": "docs"
    },
    "exclude-from-classmap": [
      "docs/"
    ]
  },
  "conflict": {
    "thecodingmachine/safe": "<3.0.0"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
